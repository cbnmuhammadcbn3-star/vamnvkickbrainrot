-- Event listeners
LocalPlayer.CharacterAdded:Connect(function()
    wait(0.5)
    updateChar()
end)

-- Main loop
RunService.RenderStepped:Connect(function()
    if not isRunning then return end
    updateChar()
    
    if character and humanoid and rootPart and humanoid.Health > 0 then
        doKick()
        doSell()
        doCollect()
    end
end)

