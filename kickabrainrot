-- KICK A BRAINROT - ULTIMATE AUTO FARM
-- Author: mizu verse
-- Version: 2.0 (Aggressive Mode)
-- Fitur: Auto Kick | Auto Sell | Auto Collect Coin

-- ========== [ SETTINGS ] ==========
local Settings = {
    AutoKick = true,
    AutoSell = true,
    AutoCollect = true,
    AggressiveMode = true,      -- Mode lebih agresif dalam mengejar target
    KickRange = 35,              -- Jarak tendang (studs)
    SellRange = 60,              -- Jarak jual
    CollectRange = 50,           -- Jarak koin
    KickCooldown = 0.08,         -- Kecepatan tendang (detik)
    WalkSpeedBoost = 28,         -- Kecepatan jalan
    JumpPowerBoost = 70          -- Loncat lebih tinggi
}

-- ========== [ SERVICES ] ==========
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

-- ========== [ VARIABLES ] ==========
local character = nil
local humanoid = nil
local rootPart = nil
local lastKickTime = 0
local currentTarget = nil
local isRunning = true

-- ========== [ FUNCTIONS ] ==========
local function updateChar()
    character = LocalPlayer.Character
    if character then
        humanoid = character:FindFirstChild("Humanoid")
        rootPart = character:FindFirstChild("HumanoidRootPart")
        if humanoid and Settings.WalkSpeedBoost then
            humanoid.WalkSpeed = Settings.WalkSpeedBoost
            humanoid.JumpPower = Settings.JumpPowerBoost
        end
    end
end

-- Cari enemy terdekat (Brainrot)
local function getNearestEnemy()
    local closest = nil
    local minDist = Settings.KickRange
    
    if not rootPart then return nil end
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= character then
            local hum = obj:FindFirstChild("Humanoid")
            local humRoot = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso")
            
            if hum and hum.Health > 0 and humRoot then
                local nama = obj.Name:lower()
                if nama:find("brainrot") or nama:find("enemy") or nama:find("bot") or nama:find("zombie") or nama:find("monster") then
                    local dist = (rootPart.Position - humRoot.Position).Magnitude
                    if dist < minDist then
                        closest = obj
                        minDist = dist
                    end
                end
            end
        end
    end
    return closest
end

-- Auto Kick (Agresif)
local function doKick()
    if not Settings.AutoKick then return end
    if not character or not humanoid or not rootPart then updateChar() return end
    
    local target = getNearestEnemy()
    currentTarget = target
    
    if target then
        local targetRoot = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Torso")
        if targetRoot then
            local dist = (rootPart.Position - targetRoot.Position).Magnitude
            local now = tick()
            
            -- Mode agresif: gerak terus ke target
            if Settings.AggressiveMode and dist > 10 then
                humanoid:MoveTo(targetRoot.Position)
            end
            
            -- Kick jika dalam jangkauan
            if dist <= Settings.KickRange and now - lastKickTime >= Settings.KickCooldown then
                -- Coba berbagai method kick
                local kicked = false
                
                -- Method 1: Remote event
                local kickRemote = ReplicatedStorage:FindFirstChild("KickEvent") or 
                                  ReplicatedStorage:FindFirstChild("Attack") or
                                  ReplicatedStorage:FindFirstChild("Damage")
                if kickRemote then
                    kickRemote:FireServer(target)
                    kicked = true
                end
                
                -- Method 2: Click pada target
                if not kicked and targetRoot then
                    local camera = Workspace.CurrentCamera
                    local vec, onScreen = camera:WorldToViewportPoint(targetRoot.Position)
                    if onScreen then
                        local mouse = LocalPlayer:GetMouse()
                        if mouse then
                            mouse.Target = target
                            mouse1click()
                            kicked = true
                        end
                    end
                end
                
                -- Method 3: Kirim sinyal ke player (remotes)
                if not kicked then
                    for _, remote in pairs(ReplicatedStorage:GetChildren()) do
                        if remote:IsA("RemoteEvent") and (remote.Name:lower():find("kick") or remote.Name:lower():find("attack")) then
                            pcall(function() remote:FireServer(target) end)
                        end
                    end
                end
                
                lastKickTime = now
            end
        end
    end
end

-- Auto Sell (Cari area jual)
local function doSell()
    if not Settings.AutoSell then return end
    if not rootPart then updateChar() return end
    
    local sellZone = nil
    local sellPos = nil
    
    -- Cari area jual berdasarkan nama
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Part") or obj:IsA("Model") then
            local nama = obj.Name:lower()
            if nama:find("sell") or nama:find("shop") or nama:find("trader") or nama:find("merchant") or nama:find("cashier") then
                sellZone = obj
                break
            end
        end
    end
    
    -- Cari berdasarkan warna (merah/kuning untuk sell)
    if not sellZone then
        for _, part in pairs(Workspace:GetDescendants()) do
            if part:IsA("Part") and (part.BrickColor == BrickColor.new("Bright red") or part.BrickColor == BrickColor.new("Bright yellow")) then
                sellZone = part
                break
            end
        end
    end
    
    if sellZone then
        if sellZone:IsA("Part") then
            sellPos = sellZone.Position
        elseif sellZone:FindFirstChild("HumanoidRootPart") then
            sellPos = sellZone.HumanoidRootPart.Position
        elseif sellZone:FindFirstChild("Part") then
            sellPos = sellZone.Part.Position
        end
        
        if sellPos then
            local dist = (rootPart.Position - sellPos).Magnitude
            if dist <= Settings.SellRange then
                -- Trigger sell
                local sold = false
                
                -- Cari tombol GUI
                local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
                if playerGui then
                    for _, gui in pairs(playerGui:GetChildren()) do
                        local button = gui:FindFirstChild("SellButton") or gui:FindFirstChild("Button")
                        if button and button:IsA("TextButton") then
                            button:Fire()
                            sold = true
                        end
                    end
                end
                
                -- Cari remote sell
                if not sold then
                    local sellRemote = ReplicatedStorage:FindFirstChild("SellEvent") or 
                                      ReplicatedStorage:FindFirstChild("SellItem")
                    if sellRemote then
                        sellRemote:FireServer()
                        sold = true
                    end
                end
                
                -- Simulasi klik
                if not sold then
                    local mouse = LocalPlayer:GetMouse()
                    if mouse then
                        mouse1click()
                    end
                end
            else
                -- Gerak ke sell zone
                humanoid:MoveTo(sellPos)
            end
        end
    end
end

-- Auto Collect Coin
local function doCollect()
    if not Settings.AutoCollect then return end
    if not rootPart then updateChar() return end
    
    local closestCoin = nil
    local minDist = Settings.CollectRange
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.ClassName ~= "Terrain" then
            local nama = obj.Name:lower()
            local material = obj.Material
            local color = obj.Color
            
            -- Deteksi koin
            if nama:find("coin") or nama:find("money") or nama:find("cash") or nama:find("gem") or nama:find("token") or
               (color and (color.r > 0.8 and color.g > 0.7 and color.b < 0.3)) or
               (material and material.Name == "Neon") then
               
                local dist = (rootPart.Position - obj.Position).Magnitude
                if dist < minDist then
                    closestCoin = obj
                    minDist = dist
                end
            end
        end
    end
    
    if closestCoin then
        local dist = (rootPart.Position - closestCoin.Position).Magnitude
        if dist <= 5 then
            -- collect koin
            local collected = false
            
            local collectRemote = ReplicatedStorage:FindFirstChild("CollectCoin") or 
                                 ReplicatedStorage:FindFirstChild("Pickup")
            if collectRemote then
                collectRemote:FireServer(closestCoin)
                collected = true
            end
            
            if not collected then
                humanoid:MoveTo(closestCoin.Position)
            end
        else
            humanoid:MoveTo(closestCoin.Position)
        end
    end
end

